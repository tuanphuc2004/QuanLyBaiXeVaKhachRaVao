# Tuỳ chọn — CORS khi frontend và API khác origin (vd: dev hoặc CDN).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Để trống hoặc * = mọi origin, không bật credentials CORS.

# Gửi email xác nhận lịch (tuỳ chọn)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=
